# ─────────────────────────────────────────────
# Gmail OAuth2 Credentials
# ─────────────────────────────────────────────
# Path to the credentials.json downloaded from Google Cloud Console
GMAIL_CREDENTIALS_PATH=credentials.json
# Path where the OAuth token will be stored after first login
GMAIL_TOKEN_PATH=token.json
# Gmail address to monitor and send from
GMAIL_ADDRESS=your@gmail.com

# ─────────────────────────────────────────────
# HuggingFace / Mistral Model
# ─────────────────────────────────────────────
# Model ID from HuggingFace Hub (runs locally)
HF_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.3

# ── Apple Silicon (M1/M2/M3/M4) ──────────────
# Use "mps" to run on the Apple GPU via Metal Performance Shaders.
# This is faster than "cpu" and works on all M-series chips.
# DO NOT use "auto" on Apple Silicon — it defaults to CPU, ignoring the GPU.
HF_DEVICE=mps

# bitsandbytes 4-bit quantization requires CUDA (NVIDIA GPU).
# It is NOT supported on Apple Silicon MPS — must be set to false.
# With 24 GB unified memory you can comfortably run Mistral 7B
# in float16 (~14 GB) without needing quantization at all.
HF_LOAD_IN_4BIT=false

# Max new tokens for generation.
# 24 GB unified RAM gives you headroom — 1024 is safe on M4 Pro.
HF_MAX_NEW_TOKENS=1024

# ── Apple Silicon (M1/M2/M3/M4) ──────────────
# MPS NOTE: Loading Mistral 7B (~13.5 GB) onto MPS causes "Invalid buffer size"
# or OOM errors because macOS reserves memory for the OS and GPU framebuffer,
# leaving insufficient contiguous MPS memory for a 7B model.
# Use "cpu" for stable inference on Apple Silicon. Mistral 7B in float32
# fits within 24 GB RAM and runs reliably — roughly 1-3 tokens/sec.
HF_DEVICE=cpu

# 4-bit quantization requires CUDA — not supported on MPS or CPU.
HF_LOAD_IN_4BIT=false

# Max new tokens — keep lower on CPU to reduce generation time per email.
HF_MAX_NEW_TOKENS=512

# MPS memory guard — prevents MPS from over-allocating and crashing the OS.
# Set to 0.0 to disable the upper limit (not recommended) or keep at 0.7
# to cap MPS at 70% of available memory for other MPS workloads.
PYTORCH_MPS_HIGH_WATERMARK_RATIO=0.7

# ─────────────────────────────────────────────
# Embedding Model (runs locally)
# ─────────────────────────────────────────────
# Embeddings always run on CPU (MPS has no benefit for small encoders)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ─────────────────────────────────────────────
# Vector Store
# ─────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=email_agent_knowledge

# ─────────────────────────────────────────────
# ChromaDB — disable noisy telemetry errors
# ─────────────────────────────────────────────
ANONYMIZED_TELEMETRY=false
CHROMA_TELEMETRY=false

# ─────────────────────────────────────────────
# File Storage
# ─────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ─────────────────────────────────────────────
# Email Polling
# ─────────────────────────────────────────────
# How often to check for new emails (seconds)
EMAIL_POLL_INTERVAL=60
# Number of emails to fetch per poll cycle
EMAIL_FETCH_LIMIT=10

# ─────────────────────────────────────────────
# RAG Settings
# ─────────────────────────────────────────────
RAG_TOP_K=5
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200

# ─────────────────────────────────────────────
# API Server
# ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
